{
  "commands": {
    "coverage": {
      "argv": [
        "python3",
        "scripts/run-coverage-sensor.py",
        "--suite",
        "{suite}"
      ],
      "covers": [
        "focused-tests"
      ],
      "required": true,
      "phases": [
        "fast",
        "integrated"
      ],
      "timeoutSeconds": 1800
    },
    "gitleaks": {
      "argv": [
        "python3",
        "scripts/run-gitleaks-sensor.py"
      ],
      "required": true,
      "phases": [
        "fast",
        "integrated"
      ]
    },
    "linter": {
      "argv": [
        "uv",
        "run",
        "--no-project",
        "--with",
        "ruff>=0.12,<1",
        "ruff",
        "check",
        "scripts",
        "tests"
      ],
      "required": true,
      "phases": [
        "fast",
        "integrated"
      ]
    },
    "semgrep": {
      "argv": [
        "python3",
        "scripts/run-semgrep-sensor.py",
        "--config",
        "config/semgrep.yml",
        "{changed_paths}"
      ],
      "required": true,
      "phases": [
        "fast",
        "integrated"
      ]
    }
  },
  "schema": "gauntlet.sensor-config/v1"
}
