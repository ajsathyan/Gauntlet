      "contract": {
        "expectedOutcome": "routed",
        "requiredActions": [
          {"type": "invoke_skill", "target": "refactor-codebase"}
        ],
        "forbiddenActions": [
          {"type": "invoke_skill", "target": "refactor-performance"}
        ],
        "allowedAuthorities": ["skill_routing"],
        "requiredProof": [
          {"type": "routing_evidence", "subject": "comprehensive-refactor"}
        ],
        "expectedRoutingChoice": "refactor-codebase",
        "outputBudget": {"maxMessages": 0, "maxWords": 0},
        "subjectiveCriteria": []
      },
      "arms": {
        "current": {
          "outcome": "routed",
          "actions": [
            {"type": "invoke_skill", "target": "refactor-performance", "authority": "skill_routing"}
          ],
          "proof": [
            {"type": "routing_evidence", "subject": "comprehensive-refactor", "ref": "request:shared-architecture-parity-migration", "passed": true}
          ],
          "routingChoice": "refactor-performance",
          "userVisibleMessages": [],
          "metrics": {}
        },
        "candidate": {
          "outcome": "routed",
          "actions": [
            {"type": "invoke_skill", "target": "refactor-codebase", "authority": "skill_routing"}
