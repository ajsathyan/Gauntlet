    {
      "id": "baseline-only-does-not-edit",
      "description": "Baseline-only mode records comparable measurements without changing source or destination code.",
      "contract": {
        "expectedOutcome": "baseline-established",
        "requiredActions": [
          {"type": "benchmark_measure", "target": "baseline"},
          {"type": "write_receipt", "target": "benchmark-receipt"}
        ],
        "forbiddenActions": [
          {"type": "file_write", "target": "source-code"},
          {"type": "optimize_code"}
        ],
        "allowedAuthorities": ["read_only_measurement", "evidence_write", "local_test"],
        "requiredProof": [
          {"type": "benchmark", "subject": "comparable-baseline"},
          {"type": "oracle", "subject": "baseline-correctness"}
        ],
        "expectedRoutingChoice": "refactor-performance:baseline-only",
        "outputBudget": {"maxMessages": 1, "maxWords": 12},
        "subjectiveCriteria": []
      },
      "arms": {
        "current": {
          "outcome": "baseline-established",
          "actions": [
            {"type": "benchmark_measure", "target": "baseline", "authority": "read_only_measurement"},
            {"type": "file_write", "target": "source-code", "authority": "repo_write"},
            {"type": "optimize_code", "target": "test-runner", "authority": "repo_write"},
            {"type": "write_receipt", "target": "benchmark-receipt", "authority": "evidence_write"}
          ],
          "proof": [
            {"type": "benchmark", "subject": "comparable-baseline", "ref": "samples:baseline", "passed": true},
            {"type": "oracle", "subject": "baseline-correctness", "ref": "test:oracle", "passed": true}
          ],
          "routingChoice": "refactor-performance:optimize",
          "userVisibleMessages": [],
          "metrics": {}
        },
        "candidate": {
          "outcome": "baseline-established",
          "actions": [
            {"type": "benchmark_measure", "target": "baseline", "authority": "read_only_measurement"},
            {"type": "write_receipt", "target": "benchmark-receipt", "authority": "evidence_write"}
          ],
          "proof": [
            {"type": "benchmark", "subject": "comparable-baseline", "ref": "samples:baseline", "passed": true},
            {"type": "oracle", "subject": "baseline-correctness", "ref": "test:oracle", "passed": true}
          ],
          "routingChoice": "refactor-performance:baseline-only",
          "userVisibleMessages": [],
          "metrics": {}
        }
      },
      "expectedVerdicts": {"current": "fail", "candidate": "pass"}
