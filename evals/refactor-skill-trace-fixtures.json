{
  "schemaVersion": "1.0",
  "packId": "refactor-skill-outcome-traces",
  "description": "Paired deterministic traces for refactor skill routing, authority, parity, completion, and delegation boundaries.",
  "baselineProvenance": {
    "current": "synthetic:pre-refactor-skill-family",
    "candidate": "git:72ca6c9-refactor-skill-family",
    "contractRef": "skills/refactor-codebase/SKILL.md; skills/refactor-performance/SKILL.md"
  },
  "pairs": [
    {
